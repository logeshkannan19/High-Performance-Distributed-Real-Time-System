{
  "name": "realtime-distributed-system",
  "version": "1.0.0",
  "description": "High-Performance Distributed Real-Time System using Node.js and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cluster": "pm2 start dist/index.js -i max",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:load": "artillery run benchmarks/load-test.yml",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "benchmark": "tsx benchmarks/run-benchmarks.ts",
    "monitor": "pm2 monit"
  },
  "keywords": [
    "realtime",
    "websocket",
    "distributed",
    "nodejs",
    "typescript",
    "redis",
    "scaling"
  ],
  "author": "Engineering Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "ioredis": "^5.3.2",
    "ws": "^8.14.2",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "rate-limiter-flexible": "^3.0.0",
    "circuit-breaker-js": "^0.0.19",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "amqplib": "^0.10.3",
    "bullmq": "^4.14.0",
    "ioredis-cluster": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.2",
    "tsx": "^4.6.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "artillery": "^2.0.0-31",
    "pm2": "^5.3.0",
    " autocannon": "^7.14.0",
    "tsx": "^4.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
